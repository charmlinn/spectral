{
  "name": "@spectral/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./repositories": "./src/repositories/index.ts",
    "./presets": "./src/presets/index.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "prisma:validate": "prisma validate --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@spectral/project-schema": "workspace:*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "dotenv": "^17.4.2",
    "prisma": "^7.7.0",
    "tsx": "^4.20.5"
  }
}
