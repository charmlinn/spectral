POSTGRES_USER=spectral
POSTGRES_PASSWORD=spectral
POSTGRES_DB=spectral
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=spectral
RABBITMQ_DEFAULT_PASS=spectral
RABBITMQ_DEFAULT_VHOST=spectral
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

DATABASE_URL=postgresql://spectral:spectral@127.0.0.1:5432/spectral?schema=public
SHADOW_DATABASE_URL=postgresql://spectral:spectral@127.0.0.1:5432/spectral_shadow?schema=public
AMQP_URL=amqp://spectral:spectral@127.0.0.1:5672/spectral
WEB_BASE_URL=http://127.0.0.1:3000

AMQP_PREFETCH=1
AMQP_RETRY_DELAY_MS=30000
EXPORT_MAX_ATTEMPTS=3

SSE_POLL_INTERVAL_MS=1000
SSE_HEARTBEAT_INTERVAL_MS=15000

R2_BUCKET=replace-with-real-r2-bucket
R2_ACCESS_KEY_ID=replace-with-real-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-real-r2-secret-access-key
R2_ACCOUNT_ID=
R2_REGION=auto
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
